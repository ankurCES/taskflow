+import json
+import os
+
+def archive_done(data, archive_path):
+    tasks = data.get('tasks', [])
+    done = [t for t in tasks if t.get('status') == 'done']
+    if not done:
+        return
+    if os.path.exists(archive_path) and os.path.getsize(archive_path) > 0:
+        with open(archive_path, 'r') as f:
+            archive = json.load(f)
+    else:
+        archive = {'archived': []}
+    archive.setdefault('archived', []).extend(done)
+    directory = os.path.dirname(archive_path) or '.'
+    os.makedirs(directory, exist_ok=True)
+    with open(archive_path, 'w') as f:
+        json.dump(archive, f, indent=2)
+        f.write('\n')
+    data['tasks'] = [t for t in tasks if t.get('status') != 'done']
+
+def restore(data, archive_path, task_id):
+    if not os.path.exists(archive_path) or os.path.getsize(archive_path) == 0:
+        raise ValueError(f"task {task_id!r} not found in archive")
+    with open(archive_path, 'r') as f:
+        archive = json.load(f)
+    archived = archive.get('archived', [])
+    found = None
+    kept = []
+    for t in archived:
+        if found is None and t.get('id') == task_id:
+            found = t
+        else:
+            kept.append(t)
+    if found is None:
+        raise ValueError(f"task {task_id!r} not found in archive")
+    archive['archived'] = kept
+    with open(archive_path, 'w') as f:
+        json.dump(archive, f, indent=2)
+        f.write('\n')
+    data.setdefault('tasks', []).append(found)
